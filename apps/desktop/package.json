{
  "name": "@lumen/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Lumen IDE desktop app",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm renderer:dev\" \"pnpm electron:dev\"",
    "renderer:dev": "vite",
    "electron:dev": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron ./electron/main.cjs",
    "renderer:build": "vite build",
    "smoke:e2e": "node ./scripts/e2e-smoke.mjs",
    "clean": "node -e \"const fs=require('node:fs');['dist','release','.vite','node_modules/.vite'].forEach((dir)=>fs.rmSync(dir,{recursive:true,force:true}));\"",
    "build": "pnpm renderer:build && electron-builder",
    "postinstall": "node ./node_modules/electron/install.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@lumen/core-agent": "workspace:*",
    "@lumen/llm-client": "workspace:*",
    "@monaco-editor/react": "^4.7.0",
    "clsx": "^2.1.1",
    "diff": "^7.0.0",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.0.0",
    "playwright-core": "^1.58.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^2.1.7",
    "simple-git": "^3.28.0",
    "tailwind-merge": "^3.3.1",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/diff": "^7.0.1",
    "@types/node": "^24.3.1",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "eslint": "^9.35.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.42.0",
    "vite": "^7.1.3",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.lumen.ide",
    "productName": "Lumen IDE",
    "asarUnpack": [
      "electron/runtime/**"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  }
}

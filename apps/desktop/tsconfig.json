{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@lumen/core-agent": ["../../packages/core-agent/src/index.ts"],
      "@lumen/llm-client": ["../../packages/llm-client/src/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
